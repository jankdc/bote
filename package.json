{
  "name": "bote-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
  },
  "scripts": {
    "build": "yarn workspaces foreach -A -pt run build",
    "build:debug": "yarn workspaces foreach -A -pt run build:debug",
    "test": "yarn workspaces foreach -A -pt run test",
    "bench": "yarn workspace @bote/bench bench",
    "lint": "yarn workspaces foreach -A -p run lint",
    "format": "run-p format:prettier format:rs",
    "format:prettier": "prettier . -w",
    "format:rs": "cargo fmt",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.14.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint --fix"
    ],
    "*.@(js|ts|tsx|yml|yaml|md|json)": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "packageManager": "yarn@4.14.1"
}
