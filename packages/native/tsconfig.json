{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "moduleResolution": "Node16",
    "module": "Node16",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["."],
  "exclude": ["node_modules"]
}
