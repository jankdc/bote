{
  "name": "@botejs/bench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "imports": {
    "#lib/*": "./lib/*"
  },
  "engines": {
    "node": ">= 22.18.0"
  },
  "scripts": {
    "bench": "node scripts/matrix.ts | node scripts/report.ts",
    "bench:matrix": "node scripts/matrix.ts",
    "bench:report": "node scripts/report.ts",
    "bench:cache": "node scripts/cache.ts",
    "profile:rust": "node scripts/profile-rust.ts",
    "profile:js": "node --expose-gc scripts/profile-js.ts",
    "stress": "node scripts/stress.ts",
    "showcase": "node scripts/showcase.ts",
    "footprint": "node scripts/footprint.ts",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@botejs/core": "*",
    "@botejs/native": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^1.14.0"
  }
}
