{
  "name": "bote-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">= 22.18.0"
  },
  "scripts": {
    "build": "npm run build -w @botejs/native && npm run build -w @botejs/core",
    "build:debug": "npm run build:debug -w @botejs/native && npm run build:debug -w @botejs/core",
    "test": "npm run test -w @botejs/native -w @botejs/core",
    "bench": "npm run bench -w @botejs/bench",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier . -w && cargo fmt",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky",
    "version-packages": "changeset version && npm run build:debug -w @botejs/native"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "oxlint": "^1.14.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.0"
  },
  "prettier": {
    "printWidth": 120,
    "semi": true,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  }
}
